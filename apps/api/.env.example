PORT=3001
DEV_AUTH=true
DATABASE_URL=postgres://lava:lava_dev@localhost:5433/lava_rapido
REDIS_URL=redis://localhost:6380/0

# Produção (Keycloak JWKS — preferido quando KEYCLOAK_ISSUER definido)
KEYCLOAK_ISSUER=
JWT_SECRET=substitua-por-segredo-longo-em-producao
CORS_ORIGIN=http://localhost:3012

# MinIO (local: docker compose; VPS: http://minio:9000 na rede Swarm)
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=https://apis3.stratostech.com.br
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=lava-rapido
MINIO_REGION=eu-south

# Bootstrap (somente primeiro deploy container)
RUN_DB_PUSH=false
RUN_DB_SEED=false
