{
  "name": "lava-rapido",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "next dev -p 3012",
    "dev:api": "PORT=3011 DEV_AUTH=true DATABASE_URL=postgres://lava:lava_dev@localhost:5433/lava_rapido REDIS_URL=redis://localhost:6380/0 npm --workspace=@lava-rapido/api run dev",
    "build": "next build",
    "build:api": "npm --workspace=@lava-rapido/api run build",
    "setup": "bash scripts/setup.sh",
    "start": "next start",
    "lint": "eslint",
    "test:api": "npm --workspace=@lava-rapido/api run test",
    "test:shared": "npm --workspace=@lava-rapido/shared run test"
  },
  "dependencies": {
    "@lava-rapido/api-client": "*",
    "@lava-rapido/shared": "*",
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
