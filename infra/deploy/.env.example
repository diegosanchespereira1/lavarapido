# Lava Rápido — variáveis para deploy (CLI ou Portainer)
# cp .env.example .env  →  editar  →  ./deploy.sh
# Portainer: use portainer.env.example (formato idêntico, sem comentários longos)

# --- Obrigatórias ---
POSTGRES_PASSWORD=CHANGE_ME_postgres
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak
MINIO_ROOT_USER=COLE_O_MINIO_ROOT_USER_DO_SEU_STACK
MINIO_ROOT_PASSWORD=COLE_O_MINIO_ROOT_PASSWORD_DO_SEU_STACK

# --- Domínios ---
WEB_HOST=lava.stratostech.com.br
API_HOST=apilava.stratostech.com.br
KEYCLOAK_HOST=authlava.stratostech.com.br
KEYCLOAK_HOSTNAME=https://authlava.stratostech.com.br
KEYCLOAK_ISSUER=https://authlava.stratostech.com.br/realms/lava-rapido
KEYCLOAK_REALM=lava-rapido
KEYCLOAK_CLIENT_ID=lava-rapido-web

# --- Rede / Traefik ---
DOCKER_NETWORK=HMLStratosNetwork
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencryptresolver

# --- Postgres ---
POSTGRES_USER=lava
POSTGRES_DB=lava_rapido

# --- Keycloak ---
KEYCLOAK_ADMIN=admin

# --- Auth ---
DEV_AUTH=true
JWT_SECRET=XhXB9isCDyLRnfrSZnA5pbxlFe/myzu1fTyIynRAUGUJhDTUXqtEI0Azwdmrpsvf

# --- MinIO (mesmos nomes do seu stack MinIO Swarm) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=https://apis3.stratostech.com.br
MINIO_ROOT_USER=COLE_O_MINIO_ROOT_USER_DO_SEU_STACK
MINIO_ROOT_PASSWORD=COLE_O_MINIO_ROOT_PASSWORD_DO_SEU_STACK
MINIO_BUCKET=lava-rapido
MINIO_REGION=eu-south
# Aliases opcionais (API aceita os dois nomes):
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=

# --- Bootstrap ---
RUN_DB_PUSH=true
RUN_DB_SEED=true

# --- Imagens Docker Hub (build/push no Mac — ver push-dockerhub.sh) ---
DOCKERHUB_USER=stratostech
IMAGE_TAG=latest
LAVA_API_IMAGE=stratostech/lava-rapido-api:latest
LAVA_WEB_IMAGE=stratostech/lava-rapido-web:latest
LAVA_KEYCLOAK_IMAGE=stratostech/lava-keycloak:latest

# --- CLI deploy.sh ---
STACK_NAME=lava-rapido
