# =============================================================================
# Lava Rápido — VPS (Portainer + Traefik + MinIO na HMLStratosNetwork)
# cp .env.example .env  →  preencher  →  ./deploy.sh
# =============================================================================

STACK_NAME=lava-rapido

# --- Domínios (DNS → VPS, Traefik Host rules) ---
WEB_HOST=lava.stratostech.com.br
API_HOST=apilava.stratostech.com.br
KEYCLOAK_HOST=authlava.stratostech.com.br

KEYCLOAK_HOSTNAME=https://authlava.stratostech.com.br
KEYCLOAK_ISSUER=https://authlava.stratostech.com.br/realms/lava-rapido
KEYCLOAK_REALM=lava-rapido
KEYCLOAK_CLIENT_ID=lava-rapido-web

# --- PostgreSQL ---
POSTGRES_USER=lava
POSTGRES_PASSWORD=troque-esta-senha-postgres
POSTGRES_DB=lava_rapido

# --- Keycloak admin console ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=troque-esta-senha-keycloak

# --- Auth ---
# true  = login demo dev-admin / dev-operator (recomendado no 1º deploy)
# false = JWT Keycloak (realm importado automaticamente)
DEV_AUTH=true
JWT_SECRET=substitua-por-segredo-longo-opcional

# --- MinIO (mesmas credenciais do seu stack MinIO) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=https://apis3.stratostech.com.br
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=lava-rapido
MINIO_REGION=eu-south

# --- Bootstrap (1º deploy: true; depois: false) ---
RUN_DB_PUSH=true
RUN_DB_SEED=true

# --- Imagens (build local via deploy.sh) ---
LAVA_API_IMAGE=lava-rapido-api:latest
LAVA_WEB_IMAGE=lava-rapido-web:latest
